<Window x:Class="SecureFileVault.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FB">
    <Grid>
        <Border Width="400"
                Padding="30"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Create Account"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Username" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameTextBox" Height="35" Margin="0,0,0,16" Padding="8"/>

                <TextBlock Text="Email" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailTextBox" Height="35" Margin="0,0,0,16" Padding="8"/>

                <TextBlock Text="Password" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Height="35" Margin="0,0,0,24" Padding="8"/>

                <Button Content="Create Account"
                        Height="38"
                        Margin="0,0,0,12"
                        Click="CreateAccountButton_Click"/>

                <Button Content="Back to Login"
                        Height="38"
                        Click="BackToLoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>