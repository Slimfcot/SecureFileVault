<Window x:Class="SecureFileVault.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure File Vault - Login"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FB">
    <Grid>
        <Border Width="380"
                Padding="30"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Secure File Vault"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Sign in to continue"
                           FontSize="14"
                           Foreground="Gray"
                           Margin="0,0,0,24"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Email"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="EmailTextBox"
                         Height="35"
                         Margin="0,0,0,16"
                         Padding="8"/>

                <TextBlock Text="Password"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             Margin="0,0,0,24"
                             Padding="8"/>

                <Button x:Name="LoginButton"
                        Content="Login"
                        Height="38"
                        Margin="0,0,0,12"
                        Click="LoginButton_Click"/>

                <Button x:Name="OpenSignUpButton"
                        Content="Create Account"
                        Height="38"
                        Click="OpenSignUpButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>